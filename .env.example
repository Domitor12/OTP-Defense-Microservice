# ─── Application ───────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
API_PREFIX=/api/v1

# ─── PostgreSQL ─────────────────────────────────────
POSTGRES_USER=otp_defense
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=otp_defense_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── Redis ──────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_change_me
REDIS_DB=0

# ─── Rate Limiting Thresholds ──────────────────────
FAILED_LOGIN_WINDOW_SECONDS=300
FAILED_LOGIN_MAX_ATTEMPTS=3
OTP_REQUEST_WINDOW_SECONDS=600
OTP_REQUEST_MAX_ATTEMPTS=2

# ─── Security ───────────────────────────────────────
API_AUTH_TOKEN=super_secret_bearer_token_for_internal_services